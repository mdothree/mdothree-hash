# mdothree-hash — environment variables
# ─────────────────────────────────────────────────────────────
# This project is fully static (no build step). Environment
# variables are injected into HTML via <meta> tags at deploy time.
# See vercel.json for how to map these to the meta tag values.
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Firebase ──────────────────────────────────────────────────
FIREBASE_API_KEY=REPLACE_WITH_FIREBASE_API_KEY
FIREBASE_AUTH_DOMAIN=REPLACE.firebaseapp.com
FIREBASE_PROJECT_ID=REPLACE_WITH_PROJECT_ID
FIREBASE_STORAGE_BUCKET=REPLACE.appspot.com
FIREBASE_MESSAGING_SENDER_ID=REPLACE_WITH_SENDER_ID
FIREBASE_APP_ID=REPLACE_WITH_APP_ID

# ── Stripe ────────────────────────────────────────────────────
# Publishable key only — never put the secret key in frontend code
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_WITH_STRIPE_PUBLISHABLE_KEY
STRIPE_PRICE_ID_MONTHLY=price_REPLACE_WITH_MONTHLY_PRICE_ID
STRIPE_PRICE_ID_YEARLY=price_REPLACE_WITH_YEARLY_PRICE_ID
STRIPE_CUSTOMER_PORTAL_URL=https://billing.stripe.com/p/login/REPLACE
